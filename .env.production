# Django Production Settings
DEBUG=False
SECRET_KEY=your-super-secret-key-here-generate-using-python-secrets
DJANGO_SETTINGS_MODULE=config.settings.production

# Server Configuration
ALLOWED_HOSTS=your-domain.com,www.your-domain.com,your-server-ip
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# CSRF Configuration (same as ALLOWED_ORIGINS for production)
CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Database Configuration (PostgreSQL recommended for production)
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://chatbot_user:your_secure_db_password@localhost:5432/chatbot_db

# AI Provider Configuration
AI_PROVIDER=claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ENABLE_DUMMY_PROVIDER=False

# Model Configuration (optional - defaults provided)
CLAUDE_MODEL=claude-3-5-haiku-20241022
OPENAI_MODEL=gpt-4
DUMMY_MODEL=dummy-1.0

# Bot Configuration
BOT_NAME=Adinvestor Assistant
BOT_POWERED_BY=Adinvestor
BOT_COLOR=#e1216f
BOT_MSG_BG_COLOR=#e1216f
BOT_ICON=https://adinvestor.com/assets/images/push_monster_circle.svg
CLAUDE_BOT_NAME=Claude Assistant
OPENAI_BOT_NAME=GPT Assistant
DUMMY_BOT_NAME=Dummy Assistant

# Session Configuration (optional - defaults to 30 minutes)
# CHAT_SESSION_TIMEOUT=1800

# File Upload Configuration (optional - defaults to 10MB)
# FILE_UPLOAD_MAX_MEMORY_SIZE=10485760

# Security Settings (uncomment for enhanced security)
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# SECURE_BROWSER_XSS_FILTER=True
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=True
